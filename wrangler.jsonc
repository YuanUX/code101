{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "code101",
  "main": "src/index.ts",
  "compatibility_date": "2025-04-01",
  "assets": {
    "directory": "./public"
  },
  "ai": {
    "binding": "AI"
  },
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "code101.work",
      "custom_domain": true
    }
  ]
}
